# Backend Environment Variables

# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=astra_lms
DB_PORT=3306

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# CORS
CORS_ORIGIN=http://localhost:5173

# Optional API key gate for all /api routes (except /api/health)
API_KEY=your_optional_public_api_key

# Required only for /api/auth/register-admin
ADMIN_SETUP_KEY=your_admin_setup_key

# Optional bootstrap admin for `npm run create-admin`
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisStrongPassword123!
