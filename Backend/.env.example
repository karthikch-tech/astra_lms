# Backend Environment Variables

# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=astra_lms
DB_PORT=3306

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# CORS
# Comma-separated list of allowed origins
CORS_ORIGIN=https://astralms.vercel.app

# API key gate for all /api routes (required)
API_KEY=your_generated_api_key

# Required only for /api/auth/register-admin (must match frontend header x-admin-setup-key)
ADMIN_SETUP_KEY=your_admin_setup_key_value

# Optional bootstrap admin for `npm run create-admin`
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisStrongPassword123!
